{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "kraken-engine",
  "version-semver": "1.7.2",
  "description": "A 2D videogame development framework.",
  "homepage": "https://krakenengine.org/",
  "builtin-baseline": "256acc64012b23a13041d8705805e1f23b43a024",
  "dependencies": [
    "box2d",
    "pugixml",
    {
      "name": "sdl3",
      "features": [
        "vulkan"
      ]
    },
    {
      "name": "sdl3-image",
      "features": [
        "jpeg",
        "png"
      ]
    },
    {
      "name": "sdl3-mixer",
      "features": [
        "libflac",
        "libvorbis",
        "mpg123",
        "opusfile"
      ]
    },
    {
      "name": "sdl3-shadercross",
      "platform": "(windows & !arm32 & !uwp & !xbox) | (linux & x64)"
    },
    {
      "name": "sdl3-ttf",
      "features": [
        "harfbuzz"
      ]
    },
    {
      "name": "spdlog",
      "features": [
        "fmt"
      ]
    },
    "tmxlite",
    "zstd"
  ],
  "overrides": [
    {
      "name": "box2d",
      "version": "3.1.1"
    },
    {
      "name": "sdl3",
      "version": "3.4.0"
    },
    {
      "name": "sdl3-image",
      "version": "3.4.0"
    },
    {
      "name": "sdl3-mixer",
      "version": "3.2.0"
    },
    {
      "name": "sdl3-shadercross",
      "version": "3.0.0-preview2"
    },
    {
      "name": "sdl3-ttf",
      "version": "3.2.2"
    },
    {
      "name": "spdlog",
      "version": "1.17.0"
    },
    {
      "name": "tmxlite",
      "version": "1.4.5"
    },
    {
      "name": "zstd",
      "version": "1.5.7"
    }
  ]
}
